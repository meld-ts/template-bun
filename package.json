{
  "name": "@meld-ts/create-bun",
  "description": "A modern Bun project template with TypeScript, Biome, and first-class support for library, app, and react-app project modes.",
  "version": "1.0.7",
  "type": "module",
  "license": "MIT",
  "keywords": ["bun", "template", "typescript", "biome", "react"],
  "repository": {
    "type": "git",
    "url": "https://github.com/meld-ts/create-bun.git"
  },
  "bin": {
    "create-bun": "index.js"
  },
  "files": ["index.js", "template-lib", "template-app", "template-react-app"],
  "scripts": {
    "build": "bun build src/index.ts --outfile index.js --target bun",
    "prepublishOnly": "bun run build",
    "fmt": "biome format --write ./src",
    "lint": "biome lint --error-on-warnings ./src",
    "ts-check": "tsgo --noEmit",
    "biome-migrate": "bunx biome migrate --write"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "@typescript/native-preview": "latest"
  }
}
